# ── Supabase ──────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → project → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here
# Service role key documented below, in the Edge Function secrets section —
# it's never used by the frontend, only by Edge Functions server-side.

# ── Razorpay ─────────────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com/app/keys
# Use TEST keys during development, LIVE keys in production
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# ── Edge Function secrets (server-side only — NEVER prefix these
#    with VITE_, and never put them in the frontend .env at all in
#    production; set them with `supabase secrets set` instead — see
#    README.md "Payments" section) ──────────────────────────────
# Same value as VITE_RAZORPAY_KEY_ID above, but read by the Edge
# Functions themselves (Deno.env), not bundled into the frontend.
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
# From Razorpay Dashboard → Settings → Webhooks, after you create the
# webhook pointing at your deployed razorpay-webhook function URL.
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are auto-injected into
# every Edge Function's runtime by the Supabase platform — you do not
# need to set these yourself for deployed functions. You only need
# them here if running `supabase functions serve` locally without
# `supabase start` (see README.md "Testing locally").
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# Optional — server-side pricing config for create-razorpay-order.
# Same meaning as the VITE_ versions below; kept separate because the
# Edge Function can't read Vite's client-side env vars.
TAX_RATE=0.18
FREE_SHIPPING_THRESHOLD=500000
SHIPPING_COST=8900

# ── App ──────────────────────────────────────────────────────────
VITE_APP_URL=http://localhost:5173
VITE_APP_NAME=RacquetIn

# ── Email (Resend) ────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here
VITE_FROM_EMAIL=noreply@racquetin.com

# ── Tax & Shipping ───────────────────────────────────────────────
# GST rate as decimal (0.18 = 18%)
VITE_TAX_RATE=0.18
# Free shipping threshold in paise (50000 = ₹500)
VITE_FREE_SHIPPING_THRESHOLD=500000
# Standard shipping cost in paise (8900 = ₹89)
VITE_SHIPPING_COST=8900

# ── Admin ────────────────────────────────────────────────────────
# Domain allowed for admin signup — prevents non-staff registration
VITE_ADMIN_EMAIL_DOMAIN=racquetin.com
